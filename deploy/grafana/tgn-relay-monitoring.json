{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": "-- Grafana --",
        "enable": true,
        "hide": true,
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "HTTP Metrics",
      "type": "row"
    },
    {
      "title": "HTTP Request Rate (RPS)",
      "type": "timeseries",
      "id": 1,
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 1 },
      "datasource": { "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum(rate(tgn_relay_http_requests_total[5m])) by (method, path, status)",
          "legendFormat": "{{method}} {{path}} ({{status}})",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth" },
          "unit": "reqps"
        }
      }
    },
    {
      "title": "HTTP Latency (Percentiles)",
      "type": "timeseries",
      "id": 2,
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 1 },
      "datasource": { "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum(rate(tgn_relay_http_request_duration_seconds_bucket[5m])) by (le, path))",
          "legendFormat": "p99 {{path}}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(tgn_relay_http_request_duration_seconds_bucket[5m])) by (le, path))",
          "legendFormat": "p95 {{path}}",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.50, sum(rate(tgn_relay_http_request_duration_seconds_bucket[5m])) by (le, path))",
          "legendFormat": "p50 (median) {{path}}",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line" },
          "unit": "s"
        }
      }
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 8 },
      "id": 200,
      "title": "Queue Status",
      "type": "row"
    },
    {
      "title": "Current Queue Depth vs Capacity",
      "type": "timeseries",
      "id": 3,
      "gridPos": { "h": 6, "w": 16, "x": 0, "y": 9 },
      "datasource": { "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "tgn_relay_queue_depth",
          "legendFormat": "Queue Depth",
          "refId": "A"
        },
        {
          "expr": "tgn_relay_queue_capacity",
          "legendFormat": "Queue Capacity",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line" },
          "unit": "none"
        }
      }
    },
    {
      "title": "Queue Full Drops",
      "type": "stat",
      "id": 4,
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 9 },
      "datasource": { "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "increase(tgn_relay_queue_full_total[5m])",
          "legendFormat": "Dropped Messages",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        }
      }
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 15 },
      "id": 300,
      "title": "Telegram Sender",
      "type": "row"
    },
    {
      "title": "Messages Enqueued Rate",
      "type": "timeseries",
      "id": 5,
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 16 },
      "datasource": { "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum(rate(tgn_relay_messages_enqueued_total[5m])) by (group, mode)",
          "legendFormat": "Enqueued ({{group}}/{{mode}})",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "mps" }
      }
    },
    {
      "title": "Telegram Delivery Success / Failure Rate",
      "type": "timeseries",
      "id": 6,
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 16 },
      "datasource": { "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "rate(tgn_relay_telegram_messages_sent_total[5m])",
          "legendFormat": "Sent Successfully",
          "refId": "A"
        },
        {
          "expr": "sum(rate(tgn_relay_telegram_messages_failed_total[5m])) by (reason)",
          "legendFormat": "Failed ({{reason}})",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "mps" }
      }
    },
    {
      "title": "Telegram Rate Limits (429)",
      "type": "stat",
      "id": 7,
      "gridPos": { "h": 3, "w": 8, "x": 16, "y": 16 },
      "datasource": { "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "increase(tgn_relay_telegram_rate_limited_total[5m])",
          "legendFormat": "429 Errors",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 1 }
            ]
          }
        }
      }
    },
    {
      "title": "Telegram Backoff (Retry After)",
      "type": "stat",
      "id": 8,
      "gridPos": { "h": 3, "w": 8, "x": 16, "y": 19 },
      "datasource": { "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "tgn_relay_telegram_retry_after_seconds",
          "legendFormat": "Retry After",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        }
      }
    }
  ],
  "refresh": "5s",
  "schemaVersion": 36,
  "style": "dark",
  "tags": [],
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timepicker": {
    "refresh_intervals": [
      "5s",
      "10s",
      "30s"
    ]
  },
  "timezone": "",
  "title": "Telegram Relay Monitoring",
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "label": "Data Source",
        "multi": false,
        "name": "DS_PROMETHEUS",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "regex": "",
        "skipUrlSync": false,
        "type": "datasource"
      }
    ]
  }
}